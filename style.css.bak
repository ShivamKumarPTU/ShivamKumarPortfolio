    :root {
      --navy: #0F172A;
      --cyan: #00ADB5;
      --muted: #64748B;
      --bg: #F8FAFC;
      --card: #FFFFFF;
      --radius: 14px;
      --container: 1200px;
    }

    * {
      box-sizing: border-box
    }

    html {
      scroll-behavior: smooth
    }

    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      color: var(--navy);
      background: var(--bg);
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }

    a {
      text-decoration: none;
      color: inherit
    }

    .container {
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 22px
    }

    header {
      position: fixed;
      left: 0;
      right: 0;
      top: 0;
      background: rgba(15, 23, 42, 0.4);
      backdrop-filter: saturate(180%) blur(20px);
      -webkit-backdrop-filter: saturate(180%) blur(20px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
      z-index: 1200;
      padding: 14px 0;
      transition: all 0.3s ease;
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between
    }

    .logo {
      font-family: 'Poppins', sans-serif;
      font-weight: 700;
      font-size: 20px;
      color: #fff;
    }

    .logo span {
      color: var(--cyan)
    }

    .nav-links {
      display: flex;
      gap: 18px;
      list-style: none;
      margin: 0;
      padding: 0
    }

    .nav-links a {
      display: inline-block;
      font-weight: 500;
      color: rgba(255, 255, 255, 0.8);
      padding: 8px 16px;
      border-radius: 99px;
      transition: all 0.4s ease;
      border: 1px solid transparent;
    }

    .nav-links a:hover {
      background: rgba(255, 255, 255, 0.1);
      color: #fff;
      border-color: rgba(255, 255, 255, 0.2);
    }

    .mobile-toggle {
      display: none;
      font-size: 24px;
      color: #fff;
      cursor: pointer;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 12px 24px;
      border-radius: 999px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: all 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      transform-style: preserve-3d;
      transform-origin: center;
    }

    .btn:hover {
      transform: perspective(800px) rotateY(360deg) scale(1.05);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    }

    .btn-primary {
      background: var(--cyan);
      color: white;
      box-shadow: 0 4px 15px rgba(0, 173, 181, 0.3);
    }

    .btn-ghost {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #fff;
      backdrop-filter: blur(5px);
    }

    .btn-ghost:hover {
      background: var(--cyan);
      border-color: var(--cyan);
      color: white;
    }

    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
    }

    .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }

    /* Premium Animations */
    .premium-reveal-mask {
      overflow: hidden;
      display: block;
      vertical-align: top;
    }

    .premium-reveal-inner {
      display: block;
      transform: translateY(110%);
      opacity: 0;
      transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1), opacity 1s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .revealed .premium-reveal-inner,
    .premium-reveal-mask.revealed .premium-reveal-inner {
      transform: translateY(0);
      opacity: 1;
    }

    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .fade-up.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* Icon Animations */
    @keyframes iconFloat {

      0%,
      100% {
        transform: translateY(0);
      }

      50% {
        transform: translateY(-6px);
      }
    }

    @keyframes iconPulse {
      0% {
        transform: scale(1);
      }

      50% {
        transform: scale(1.15) rotate(5deg);
      }

      100% {
        transform: scale(1) rotate(0);
      }
    }

    .hero-stat-card i,
    .service-icon i,
    .portfolio-image i {
      display: inline-block;
      animation: iconFloat 4s ease-in-out infinite;
    }

    .service-card:hover .service-icon i,
    .portfolio-card:hover .portfolio-image i {
      animation: iconPulse 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .btn i,
    .portfolio-cta i,
    .service-cta i {
      transition: transform 0.3s ease;
      display: inline-block;
    }

    .btn:hover i,
    .portfolio-cta:hover i,
    .service-cta:hover i {
      transform: translateX(6px) scale(1.1);
    }

    .platform a i {
      transition: transform 0.3s ease;
    }

    .platform a:hover i {
      transform: scale(1.2) rotate(-10deg);
      color: var(--cyan) !important;
    }

    section {
      padding: 100px 0;
      position: relative;
      overflow: hidden;
    }

    .section-video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -1;
      opacity: 0.4;
      pointer-events: none;
    }

    .section-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(180deg, rgba(15, 23, 42, 0.8) 0%, rgba(15, 23, 42, 0.9) 100%);
      z-index: 0;
    }

    .section-content {
      position: relative;
      z-index: 10;
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.03) !important;
      backdrop-filter: blur(12px) !important;
      -webkit-backdrop-filter: blur(12px) !important;
      border: 1px solid rgba(255, 255, 255, 0.1) !important;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2) !important;
      color: #fff !important;
    }

    .glass-card p, .glass-card li {
      color: rgba(255, 255, 255, 0.7) !important;
    }

    .glass-card h3, .glass-card h4 {
      color: #fff !important;
    }

    /* HERO */
    .hero {
      padding-top: 140px;
      position: relative;
      overflow: hidden;
      background: #000;
      color: #fff;
    }

    .hero-video {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
      opacity: 0.6;
      pointer-events: none;
    }

    .hero .container {
      position: relative;
      z-index: 1;
    }

    .glass-panel {
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      padding: 40px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.6);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .hero-grid {
      display: flex;
      justify-content: flex-start;
      align-items: flex-start;
      min-height: 650px;
    }

    .hero-stat-card {
      background: rgba(0, 0, 0, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      padding: 14px 24px;
      border-radius: 16px;
      display: flex;
      align-items: center;
      gap: 16px;
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      animation: slider3 0.8s cubic-bezier(0.25, 1, 0.5, 1) backwards;
      text-align: left;
    }

    .hero-stat-card:hover {
      transform: translateY(-8px);
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.3);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
    }

    @keyframes slider3 {
      from {
        opacity: 0;
        transform: translateX(40px) scale(0.95);
      }

      to {
        opacity: 1;
        transform: translateX(0) scale(1);
      }
    }

    .hero-title {
      font-family: 'Poppins', sans-serif;
      font-size: 2.4rem;
      line-height: 1.05;
      margin-bottom: 16px
    }

    .hero-sub {
      color: var(--muted);
      margin-bottom: 22px;
      font-size: 1.05rem
    }

    .chip {
      background: var(--card);
      padding: 10px 14px;
      border-radius: 12px;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04);
      font-weight: 600;
      color: var(--navy)
    }

    .mockup {
      display: flex;
      justify-content: center;
      align-items: center
    }

    .phone {
      width: 280px;
      height: 520px;
      border-radius: 36px;
      background: linear-gradient(180deg, #0f172a, #0b1220);
      box-shadow: 0 30px 80px rgba(15, 23, 42, 0.12);
      display: flex;
      align-items: center;
      justify-content: center
    }

    .phone-screen {
      width: 230px;
      height: 470px;
      border-radius: 28px;
      background: #fff;
      display: grid;
      place-items: center;
      padding: 18px
    }

    .mock-icons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      width: 100%
    }

    .mock-icon {
      background: var(--cyan);
      border-radius: 10px;
      padding: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 18px
    }

    /* trust */
    .trust-row {
      display: flex;
      gap: 12px;
      margin-top: 26px;
      flex-wrap: wrap
    }

    .trust-badge {
      background: var(--card);
      padding: 10px 14px;
      border-radius: 12px;
      display: flex;
      gap: 12px;
      align-items: center;
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04)
    }

    /* services */
    .section-header {
      text-align: center;
      margin-bottom: 40px
    }

    .section-header h2 {
      font-size: 2.8rem;
      margin-bottom: 12px;
      font-weight: 800;
      background: linear-gradient(135deg, #fff 0%, rgba(255, 255, 255, 0.4) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    .section-header p {
      color: rgba(255, 255, 255, 0.6) !important;
      font-size: 1.1rem;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 20px
    }

    .service {
      background: var(--card);
      padding: 22px;
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
      transition: transform .28s
    }

    .service:hover {
      transform: translateY(-8px)
    }

    .service .icon {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--cyan), #009199);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      margin-bottom: 14px
    }

    .service h3 {
      margin: 0 0 8px 0;
      font-size: 1.1rem
    }

    .service p {
      color: var(--muted);
      margin: 0 0 12px
    }

    .service .cta {
      font-weight: 600;
      color: var(--cyan)
    }

    /* CTA / pricing */
    .pricing-cta {
      display: flex;
      gap: 18px;
      align-items: center;
      justify-content: center;
      margin-top: 26px;
      flex-wrap: wrap
    }

    .pricing-card {
      background: linear-gradient(180deg, #fff, #fbfdfe);
      padding: 18px;
      border-radius: 12px;
      border: 1px solid rgba(0, 173, 181, 0.06);
      box-shadow: 0 6px 18px rgba(15, 23, 42, 0.04)
    }

    /* FAQ */
    .faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px
    }

    .faq {
      background: var(--card);
      padding: 18px;
      border-radius: 12px;
      box-shadow: 0 8px 22px rgba(15, 23, 42, 0.04)
    }

    .faq h4 {
      margin: 0 0 8px 0
    }

    /* contact */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 28px;
      align-items: start
    }

    .form-control {
      width: 100%;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid #e6edf2;
      background: #fff;
      font-size: 0.95rem
    }

    label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600
    }

    .success-message {
      background: #16a34a;
      color: #fff;
      padding: 12px;
      border-radius: 10px;
      display: none;
      margin-top: 12px
    }

    /* footer */
    footer {
      background: var(--navy);
      color: #fff;
      padding: 40px 0;
      border-top: 4px solid rgba(255, 255, 255, 0.03)
    }

    .footer-grid {
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
      justify-content: space-between
    }

    .socials a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.06);
      margin-right: 8px;
      color: #fff
    }

    .availability-bar {
      position: relative;
      border-top: 1px solid rgba(0, 173, 181, 0.08);
      border-bottom: 1px solid rgba(0, 173, 181, 0.08);
      margin: 0;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.02);
    }

    .availability-bar:hover .availability-track {
      animation-play-state: paused;
    }

    @keyframes scroll {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-33.33%);
      }
    }

    .platform a {
      transition: all 0.2s ease;
      padding: 6px 12px;
      border-radius: 8px;
    }

    .platform a:hover {
      background: rgba(0, 173, 181, 0.06);
      color: var(--cyan);
      transform: translateY(-1px);
    }

    /* Responsive adjustments */
    @media (max-width: 992px) {
      .mobile-toggle {
        display: block;
      }

      .nav-links {
        position: fixed;
        top: 0;
        right: -100%;
        width: 80%;
        height: 100vh;
        background: rgba(15, 23, 42, 0.95);
        backdrop-filter: blur(20px);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 2000;
        gap: 30px;
      }

      .nav-links.active {
        right: 0;
      }

      .nav-links a {
        font-size: 1.2rem;
        width: 100%;
        text-align: center;
      }
    }
    @media (max-width: 720px) {
      .availability-track {
        animation: scroll 25s linear infinite !important;
      }
    }

    @media (max-width: 576px) {
      .availability-track {
        animation: scroll 20s linear infinite !important;
      }

      .platform {
        padding: 0 14px !important;
      }

      .platform a {
        margin: 0 8px !important;
        font-size: 0.9rem;
      }
    }

    /* Service Cards Styles */
    .services {
      background: var(--off-white)
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px
    }

    .service-card {
      background: white;
      border-radius: 15px;
      overflow: hidden;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
      transition: all 0.3s ease
    }

    .service-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1)
    }

    .service-icon {
      height: 120px;
      background: var(--cyan);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 40px;
      color: white
    }

    .service-content {
      padding: 30px
    }

    .service-content h3 {
      margin-bottom: 15px;
      font-size: 1.5rem
    }

    .service-content p {
      margin-bottom: 20px;
      color: var(--muted)
    }

    .service-cta {
      display: inline-block;
      color: var(--cyan);
      font-weight: 500;
      text-decoration: none;
      transition: all 0.3s ease
    }

    .service-cta:hover {
      transform: translateX(5px)
    }

    .services-cta {
      text-align: center;
      margin-top: 50px
    }

    /* Tech Stack Cards Styles */
    .tech-stack {
      background: white
    }

    .tech-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px
    }

    .tech-card {
      background: var(--off-white);
      border-radius: 15px;
      padding: 30px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
      transition: all 0.3s ease;
      border: 2px solid transparent
    }

    .tech-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
      border-color: var(--cyan)
    }

    .tech-card-header {
      display: flex;
      align-items: center;
      gap: 15px;
      margin-bottom: 25px
    }

    .tech-card-header i {
      font-size: 32px;
      color: var(--cyan)
    }

    .tech-card-header h3 {
      font-size: 1.3rem;
      color: var(--navy);
      margin: 0
    }

    .tech-list {
      list-style: none;
      padding: 0;
      margin: 0
    }

    .tech-list li {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px 0;
      color: var(--dark-gray);
      font-size: 0.95rem
    }

    .tech-dot {
      width: 8px;
      height: 8px;
      background: var(--cyan);
      border-radius: 50%;
      flex-shrink: 0
    }

    .tech-list li:hover {
      color: var(--navy);
      font-weight: 500
    }

    /* Portfolio Cards Styles */
    .portfolio {
      background: white
    }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 30px
    }

    .portfolio-card {
      border-radius: 16px;
      overflow: hidden;
      background: white;
      box-shadow: 0 18px 30px rgba(2, 6, 23, 0.04);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
      cursor: pointer
    }

    .portfolio-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 28px 50px rgba(2, 6, 23, 0.08)
    }

    .portfolio-image {
      height: 200px;
      background: var(--cyan);
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 34px;
      border-top-left-radius: 16px;
      border-top-right-radius: 16px
    }

    .portfolio-content {
      padding: 28px 26px 32px;
      flex: 1 0 auto
    }

    .portfolio-content h3 {
      margin: 0 0 8px 0
    }

    .portfolio-content p {
      color: var(--dark-gray);
      margin-bottom: 12px
    }

    .portfolio-tech {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 20px
    }

    .project-tag {
      display: inline-block;
      background: #f3f7f8;
      color: var(--navy);
      padding: 8px 12px;
      border-radius: 20px;
      margin: 6px 8px 0 0;
      font-size: 0.88rem
    }

    .tech-tag {
      background: var(--off-white);
      padding: 5px 12px;
      border-radius: 20px;
      font-size: 0.85rem;
      color: var(--dark-gray)
    }

    .portfolio-cta {
      display: inline-block;
      color: var(--cyan);
      font-weight: 500;
      text-decoration: none;
      margin-top: 18px
    }

    .hidden-project {
      display: none !important
    }

    .view-more {
      text-align: center;
      margin-top: 50px
    }

    /* Testimonials Cards Styles */
    .testimonials {
      background: var(--off-white);
      overflow: hidden;
      position: relative;
    }

    .testimonial-carousel {
      display: flex;
      width: max-content;
      gap: 30px;
      animation: marquee 30s linear infinite;
      padding: 10px 0;
    }

    .testimonial-carousel:hover {
      animation-play-state: paused;
    }

    .testimonial-card {
      background: white;
      padding: 28px 30px;
      border-radius: 16px;
      box-shadow: 0 18px 30px rgba(2, 6, 23, 0.06);
      width: 350px;
      flex-shrink: 0;
      white-space: normal;
    }

    .testimonial-text {
      font-style: italic;
      margin-bottom: 22px;
      color: var(--dark-gray);
      line-height: 1.6
    }

    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 15px
    }

    .author-avatar {
      width: 50px;
      height: 50px;
      background: var(--cyan);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold
    }

    .author-info h4 {
      margin-bottom: 5px
    }

    .author-info p {
      color: var(--dark-gray);
      font-size: 0.9rem
    }

    @keyframes marquee {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(calc(-50% - 15px));
      }
    }

    /* responsiveness */
    @media(max-width:1000px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      .contact-grid {
        grid-template-columns: 1fr
      }

      .faq-grid {
        grid-template-columns: 1fr
      }
    }

    @media(max-width:720px) {
      .nav-links {
        display: none
      }

